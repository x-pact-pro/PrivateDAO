PRIMARY_DOMAIN=privatedao.org
ACME_EMAIL=ops@privatedao.org

# Local verification bind ports. Keep these non-privileged during rehearsal.
PRIMARY_LOCAL_HTTP_BIND_PORT=8080
PRIMARY_EDGE_HTTP_BIND_PORT=8081
PRIMARY_EDGE_HTTPS_BIND_PORT=8443

# Read-node runtime settings
PRIVATE_DAO_PROGRAM_ID=EP9xE8MJZ6FfyEwLqns6HDdUZBknEa7WGYs1Jzsecuva
PRIVATE_DAO_READ_NODE_HOST=0.0.0.0
PRIVATE_DAO_READ_NODE_PORT=8787
PRIVATE_DAO_READ_ALLOWED_ORIGIN=https://privatedao.org
PRIVATE_DAO_READ_CACHE_TTL_MS=15000
PRIVATE_DAO_READ_RATE_WINDOW_MS=60000
PRIVATE_DAO_READ_RATE_LIMIT=180
PRIVATE_DAO_RPC_TIMEOUT_MS=12000
MAGICBLOCK_HTTP_TIMEOUT_MS=2500

# Optional Telegram notifications.
# Use either a generic webhook that accepts {"text":"..."} or Telegram Bot API credentials.
PRIVATE_DAO_TELEGRAM_WEBHOOK_URL=
PRIVATE_DAO_TELEGRAM_BOT_TOKEN=
PRIVATE_DAO_TELEGRAM_CHAT_ID=
PRIVATE_DAO_TELEGRAM_VISITOR_NOTIFICATIONS=true
PRIVATE_DAO_TELEGRAM_VISITOR_MIN_INTERVAL_MS=60000
PRIVATE_DAO_TELEGRAM_VISITOR_SESSION_TTL_MS=1800000

# RPC pool configuration. Priority follows scripts/lib/read-node.ts
RPCFAST_DEVNET_RPC_URL=
RPCFAST_TESTNET_RPC_URL=
SOLANA_RPC_URL=
ALCHEMY_API_KEY=
ALCHEMY_DEVNET_RPC_URL=
HELIUS_API_KEY=
RPC_FAST_DEVNET_RPC=
QUICKNODE_DEVNET_RPC=
EXTRA_DEVNET_RPCS=

# Ika Solana pre-alpha custody route. Inject host-local keypair path as a secret.
IKA_PREALPHA_GRPC_URL=https://pre-alpha-dev-1.ika.ika-network.net:443
IKA_PREALPHA_SOLANA_RPC=https://api.devnet.solana.com
IKA_PREALPHA_PROGRAM_ID=87W54kGYFQ1rgWqMeu4XTPHWXWmXSQCcjm8vCTfiq1oY
IKA_SOLANA_KEYPAIR_PATH=

# RPCFast Hackathon/Aperture streaming configuration.
# Never commit real API keys. Inject these as host secrets.
RPCFAST_DEVNET_YELLOWSTONE_GRPC_ENDPOINT=
RPCFAST_DEVNET_YELLOWSTONE_GRPC_API_KEY=
RPCFAST_TESTNET_YELLOWSTONE_GRPC_ENDPOINT=
RPCFAST_TESTNET_YELLOWSTONE_GRPC_API_KEY=
RPCFAST_MAINNET_APERTURE_GRPC_ENDPOINT=
RPCFAST_MAINNET_APERTURE_GRPC_API_KEY=
RPCFAST_MAINNET_SHREDSTREAM_GRPC_ENDPOINT=
RPCFAST_MAINNET_SHREDSTREAM_GRPC_API_KEY=
RPCFAST_MAINNET_YELLOWSTONE_GRPC_ENDPOINT=
RPCFAST_MAINNET_YELLOWSTONE_GRPC_API_KEY=
