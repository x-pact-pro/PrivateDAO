{
	email {$ACME_EMAIL}
}

(privatedao_primary_host) {
	root * /srv/privatedao/site
	encode gzip zstd

	header {
		X-PrivateDAO-Primary-Host "candidate"
		X-PrivateDAO-Backup-Policy "github-pages-backup-only"
	}

	@health path /healthz /api/health
	handle @health {
		reverse_proxy read-node:8787
	}

	@api path /api/v1 /api/v1/*
	handle @api {
		reverse_proxy read-node:8787
	}

	@quicknode_root {
		method POST
		path /
	}
	handle @quicknode_root {
		rewrite * /api/v1/quicknode/stream
		reverse_proxy read-node:8787
	}

	handle {
		try_files {path} {path}/index.html /thesis/index.html /index.html
		file_server
	}
}

:8080 {
	import privatedao_primary_host
}

api.privatedao.org {
	import privatedao_primary_host
}

www.privatedao.org {
	redir https://privatedao.org{uri} permanent
}

privatedao.org {
	import privatedao_primary_host
}
